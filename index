<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Acredita que eu...</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --orange:   #FF6600;
  --orange-d: #cc5200;
  --orange-l: #ff8533;
  --orange-xl:#fff0e6;
  --dark:     #1C1C1C;
  --mid:      #4a4a4a;
  --muted:    #888;
  --line:     rgba(0,0,0,0.08);
  --white:    #ffffff;
  --cream:    #E1D8C8;
  --green-ok: #1a7a3a;
  --red-err:  #cc2200;
  --surface:  #fff;
  --bg:       #FF6600;
  --r:        10px;
  --shadow:   0 2px 12px rgba(0,0,0,0.10);
  --shadow-lg:0 8px 32px rgba(0,0,0,0.16);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  font-family:'Inter',sans-serif;
  background:var(--bg);
  color:var(--dark);
  min-height:100vh;
}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh;}
.screen.active{display:flex;flex-direction:column;align-items:center;}

/* ══════════════════════════════════════════════
   SETUP SCREEN
══════════════════════════════════════════════ */
#setupScreen{padding:40px 16px;}
.brand{
  display:flex;align-items:baseline;gap:10px;
  margin-bottom:4px;
}
.brand-logo{
  font-size:clamp(2rem,5vw,3rem);
  font-weight:800;
  color:#fff;
  letter-spacing:-1px;
  line-height:1;
}
.brand-logo span{color:var(--dark);}
.brand-sub{
  font-size:.85rem;font-weight:500;
  color:rgba(255,255,255,.7);
  letter-spacing:.5px;
  text-transform:uppercase;
}
.setup-tagline{
  font-size:.9rem;color:rgba(255,255,255,.7);
  margin-bottom:36px;font-weight:400;
}

.card{
  background:var(--white);
  border-radius:var(--r);
  padding:28px;width:100%;max-width:660px;
  box-shadow:var(--shadow-lg);
  margin-bottom:20px;
}
.card-title{
  font-size:1rem;font-weight:700;
  color:var(--dark);
  margin-bottom:18px;
  text-transform:uppercase;
  letter-spacing:.8px;
  display:flex;align-items:center;gap:8px;
}
.card-title span{color:var(--orange);}

label{
  font-size:.72rem;font-weight:700;
  color:var(--muted);
  text-transform:uppercase;letter-spacing:.8px;
  display:block;margin-bottom:5px;
}
input[type=text],textarea,select{
  width:100%;
  background:#f7f7f7;
  border:1.5px solid #e0e0e0;
  border-radius:7px;
  padding:9px 13px;
  color:var(--dark);
  font-family:'Inter',sans-serif;
  font-size:.9rem;font-weight:500;
  outline:none;
  transition:border-color .15s;
  margin-bottom:14px;
}
input:focus,textarea:focus,select:focus{border-color:var(--orange);}
textarea{resize:vertical;min-height:64px;}

/* Buttons */
.btn{
  background:var(--orange);color:#fff;
  font-family:'Inter',sans-serif;
  font-size:.85rem;font-weight:700;
  letter-spacing:.5px;
  text-transform:uppercase;
  border:none;border-radius:7px;
  padding:11px 22px;cursor:pointer;
  transition:background .15s,transform .1s;
}
.btn:hover{background:var(--orange-d);}
.btn:active{transform:scale(.98);}
.btn.lg{font-size:.95rem;padding:14px 32px;border-radius:8px;width:100%;max-width:660px;}
.btn.ghost{background:transparent;color:var(--orange);border:1.5px solid var(--orange);}
.btn.ghost:hover{background:var(--orange-xl);}
.btn.white{background:#fff;color:var(--orange);}
.btn.white:hover{background:#f5f5f5;}
.btn.danger{background:#e05050;}
.btn.sm{font-size:.75rem;padding:7px 14px;}
.btn.confirm{background:var(--green-ok);}

/* Teams */
.teams-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;}
.team-chip{
  display:flex;align-items:center;gap:8px;
  background:var(--orange-xl);
  border:1.5px solid rgba(255,102,0,.2);
  border-radius:50px;
  padding:5px 12px;font-size:.82rem;font-weight:600;
}
.chip-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;}
.chip-rm{cursor:pointer;color:var(--muted);font-size:1rem;line-height:1;margin-left:2px;}
.chip-rm:hover{color:var(--red-err);}

/* Question blocks */
.q-block{
  background:#f9f9f9;border-radius:8px;
  padding:16px;margin-bottom:14px;
  border-left:3px solid var(--orange);
}
.q-block-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.q-block-num{font-size:.8rem;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:.5px;}
.opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:8px 0 0;}
.opt-row{display:flex;align-items:center;gap:7px;}
.opt-letter{font-size:.75rem;font-weight:800;color:var(--orange);width:16px;flex-shrink:0;}
.opt-row input{margin-bottom:0;}
.correct-row{margin-top:10px;}
.correct-row select{margin-bottom:0;}

#qCount{font-size:.75rem;color:var(--muted);margin-top:10px;}
#startError{font-size:.82rem;color:#fff;background:rgba(0,0,0,.2);padding:8px 14px;border-radius:6px;margin-top:8px;display:none;}

/* ══════════════════════════════════════════════
   GAME SCREEN
══════════════════════════════════════════════ */
#gameScreen{
  background:#f4f4f4;
  flex-direction:column;
  align-items:stretch;
  padding:0;
}

/* Top bar */
.topbar{
  background:var(--orange);
  padding:12px 20px;
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:10px;
}
.topbar-logo{
  font-size:1.3rem;font-weight:800;color:#fff;
  letter-spacing:-0.5px;
}
.topbar-logo span{color:var(--dark);}
.scorebar{
  display:flex;flex-wrap:wrap;gap:6px;
}
.score-chip{
  display:flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.15);
  border-radius:50px;
  padding:4px 12px;
  font-size:.78rem;font-weight:700;color:#fff;
  border:1.5px solid rgba(255,255,255,.2);
}
.score-chip.active{background:rgba(255,255,255,.3);border-color:#fff;}
.score-chip .sc-dot{width:10px;height:10px;border-radius:50%;border:1.5px solid rgba(255,255,255,.5);}

/* Game layout */
.game-body{
  display:grid;
  grid-template-columns:1fr 240px;
  gap:16px;
  padding:16px;
  flex:1;
  max-width:1200px;
  width:100%;
  margin:0 auto;
}

/* Board */
.board-wrap{
  background:#fff;
  border-radius:var(--r);
  padding:16px;
  box-shadow:var(--shadow);
}
.board-grid{display:grid;gap:6px;}

/* Cells */
.cell{
  border-radius:8px;
  aspect-ratio:1;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  cursor:pointer;
  position:relative;
  transition:transform .12s,box-shadow .12s;
  overflow:visible;
  min-width:0;
}
.cell:hover{transform:scale(1.04);z-index:2;}
.cell.start{background:var(--dark);color:#fff;}
.cell.finish{background:var(--orange);color:#fff;}
.cell.locked{background:#fff;border:1.5px solid #e0e0e0;cursor:default;}
.cell.locked:hover{transform:none;}
.cell.open{background:#fff;border:2px solid var(--orange);}
.cell.solved{color:#fff;}  /* background set inline to team color */

.cell-num{
  font-size:clamp(.75rem,1.8vw,1.2rem);
  font-weight:800;
  line-height:1;
  color:inherit;
  opacity:.85;
}
.cell-icon{font-size:clamp(.9rem,2vw,1.3rem);line-height:1;}
.cell.locked .cell-num{color:#bbb;}

/* ── PAWNS — big, floating circles above cell ── */
.cell-pawns{
  position:absolute;
  top:-10px; left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:3px;
  z-index:10;
  pointer-events:none;
}
.pawn{
  width:clamp(18px,3vw,26px);
  height:clamp(18px,3vw,26px);
  border-radius:50%;
  border:3px solid #fff;
  box-shadow:0 2px 8px rgba(0,0,0,.35);
  flex-shrink:0;
  transition:transform .2s;
}
.pawn.active-pawn{
  outline:3px solid var(--dark);
  outline-offset:1px;
}

/* Side panel */
.side-panel{display:flex;flex-direction:column;gap:12px;}

.panel-card{
  background:#fff;
  border-radius:var(--r);
  padding:16px;
  box-shadow:var(--shadow);
}
.panel-title{
  font-size:.7rem;font-weight:700;
  color:var(--muted);
  text-transform:uppercase;letter-spacing:.8px;
  margin-bottom:12px;
  padding-bottom:8px;
  border-bottom:1px solid var(--line);
}

/* Dice */
.dice-who{
  font-size:.78rem;color:var(--muted);font-weight:500;
  margin-bottom:2px;
}
.dice-name{
  font-size:1rem;font-weight:800;
  margin-bottom:14px;min-height:22px;
}

/* ── Realistic 3-D dice ── */
.dice-scene{
  width:72px;height:72px;
  perspective:220px;
  margin:0 auto 10px;
  cursor:pointer;
  user-select:none;
}
.dice-scene:hover .dice-cube{transform:rotateX(-15deg) rotateY(20deg) scale(1.06);}
.dice-cube{
  width:72px;height:72px;
  position:relative;
  transform-style:preserve-3d;
  transform:rotateX(-20deg) rotateY(15deg);
  transition:transform .15s ease;
}
.dice-cube.rolling{animation:diceRoll3d .55s ease;}
@keyframes diceRoll3d{
  0%  {transform:rotateX(0deg)   rotateY(0deg)   scale(1);}
  20% {transform:rotateX(-90deg) rotateY(45deg)  scale(1.1);}
  50% {transform:rotateX(180deg) rotateY(-60deg) scale(.95);}
  80% {transform:rotateX(270deg) rotateY(30deg)  scale(1.05);}
  100%{transform:rotateX(360deg) rotateY(0deg)   scale(1);}
}
.dice-face{
  position:absolute;
  width:72px;height:72px;
  border-radius:10px;
  display:grid;
  padding:8px;
  background:linear-gradient(145deg,#ffffff,#e8e8e8);
  box-shadow:inset 0 0 0 1.5px rgba(0,0,0,.12);
}
.dice-face.front {transform:translateZ(36px);}
.dice-face.back  {transform:rotateY(180deg) translateZ(36px);}
.dice-face.right {transform:rotateY(90deg)  translateZ(36px);}
.dice-face.left  {transform:rotateY(-90deg) translateZ(36px);}
.dice-face.top   {transform:rotateX(90deg)  translateZ(36px);}
.dice-face.bottom{transform:rotateX(-90deg) translateZ(36px);}
/* Depth shading */
.dice-face.back  {background:linear-gradient(145deg,#d0d0d0,#bbb);}
.dice-face.right {background:linear-gradient(145deg,#e0e0e0,#ccc);}
.dice-face.left  {background:linear-gradient(145deg,#e8e8e8,#d5d5d5);}
.dice-face.top   {background:linear-gradient(145deg,#f5f5f5,#e0e0e0);}
.dice-face.bottom{background:linear-gradient(145deg,#c8c8c8,#b0b0b0);}

.dot{
  width:10px;height:10px;
  border-radius:50%;
  background:radial-gradient(circle at 35% 35%,#555,#111);
  box-shadow:0 1px 3px rgba(0,0,0,.4);
  align-self:center;justify-self:center;
}
/* Dot layouts — 1 */
.face-1{grid-template-columns:1fr;grid-template-rows:1fr;}
/* 2 */
.face-2{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;}
.face-2 .dot:nth-child(1){grid-column:1;grid-row:1;align-self:start;}
.face-2 .dot:nth-child(2){grid-column:2;grid-row:2;align-self:end;}
/* 3 */
.face-3{grid-template-columns:1fr 1fr 1fr;grid-template-rows:1fr 1fr 1fr;}
.face-3 .dot:nth-child(1){grid-column:1;grid-row:1;align-self:start;}
.face-3 .dot:nth-child(2){grid-column:2;grid-row:2;}
.face-3 .dot:nth-child(3){grid-column:3;grid-row:3;align-self:end;}
/* 4 */
.face-4{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;}
/* 5 */
.face-5{grid-template-columns:1fr 1fr 1fr;grid-template-rows:1fr 1fr 1fr;}
.face-5 .dot:nth-child(1){grid-column:1;grid-row:1;align-self:start;}
.face-5 .dot:nth-child(2){grid-column:3;grid-row:1;align-self:start;}
.face-5 .dot:nth-child(3){grid-column:2;grid-row:2;}
.face-5 .dot:nth-child(4){grid-column:1;grid-row:3;align-self:end;}
.face-5 .dot:nth-child(5){grid-column:3;grid-row:3;align-self:end;}
/* 6 */
.face-6{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr 1fr;}

.dice-result{
  text-align:center;font-size:1rem;font-weight:800;
  color:var(--orange);min-height:22px;margin-bottom:10px;
}
.btn-roll{width:100%;}

/* Turn order */
.turn-row{
  display:flex;align-items:center;gap:8px;
  padding:5px 8px;border-radius:6px;
  font-size:.8rem;font-weight:600;
  margin-bottom:3px;
  justify-content:space-between;
}
.turn-row.cur{background:var(--orange-xl);}
.turn-row.done{opacity:.4;text-decoration:line-through;}
.tr-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}

/* Discovered answers */
.discovered-section{margin-top:4px;}
.disc-subtitle{
  font-size:.68rem;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:.6px;
  margin-bottom:8px;margin-top:12px;
  padding-top:12px;
  border-top:1px solid var(--line);
}
.disc-item{
  display:flex;align-items:flex-start;gap:6px;
  padding:5px 0;
  border-bottom:1px solid #f0f0f0;
  font-size:.76rem;
}
.disc-num{
  background:var(--orange);color:#fff;
  font-size:.62rem;font-weight:700;
  border-radius:4px;padding:1px 5px;
  flex-shrink:0;margin-top:1px;
}
.disc-team-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.disc-answer{font-weight:600;color:var(--dark);line-height:1.3;}
.disc-empty{font-size:.75rem;color:#bbb;font-style:italic;}

/* ══════════════════════════════════════════════
   QUESTION MODAL
══════════════════════════════════════════════ */
.overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.55);
  z-index:200;align-items:center;justify-content:center;
  padding:16px;backdrop-filter:blur(4px);
}
.overlay.open{display:flex;}
.modal{
  background:#fff;
  border-radius:12px;
  padding:32px;
  max-width:540px;width:100%;
  box-shadow:0 24px 64px rgba(0,0,0,.25);
  animation:pop .2s ease;
}
@keyframes pop{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}
.modal-badge{
  display:inline-block;
  background:var(--orange);color:#fff;
  font-size:.72rem;font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;
  padding:3px 10px;border-radius:4px;
  margin-bottom:12px;
}
.modal-team{font-size:.9rem;font-weight:700;margin-bottom:4px;}
.modal-q{
  font-size:1.05rem;font-weight:700;
  color:var(--dark);margin-bottom:20px;line-height:1.5;
}
.opts{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.opt-btn{
  background:#f7f7f7;
  border:1.5px solid #e5e5e5;
  border-radius:8px;
  padding:10px 14px;
  font-family:'Inter',sans-serif;
  font-size:.9rem;font-weight:600;
  color:var(--dark);
  cursor:pointer;text-align:left;
  display:flex;gap:10px;align-items:center;
  transition:border-color .12s,background .12s;
}
.opt-btn:hover{border-color:var(--orange);background:var(--orange-xl);}
.opt-key{font-weight:800;color:var(--orange);width:18px;flex-shrink:0;}
.opt-btn.correct{background:#e6f5ec;border-color:var(--green-ok);color:var(--green-ok);}
.opt-btn.wrong  {background:#fdecea;border-color:var(--red-err);color:var(--red-err);}
.modal-result{
  font-size:.95rem;font-weight:700;
  text-align:center;padding:10px;border-radius:7px;
  margin-bottom:16px;display:none;
}
.modal-result.ok {background:#e6f5ec;color:var(--green-ok);display:block;}
.modal-result.no {background:#fdecea;color:var(--red-err);display:block;}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;}

/* ══════════════════════════════════════════════
   VICTORY
══════════════════════════════════════════════ */
#victoryScreen{
  background:var(--orange);
  justify-content:center;align-items:center;
  gap:16px;padding:40px 16px;text-align:center;
}
.v-trophy{font-size:5rem;animation:vb 1s infinite alternate;}
@keyframes vb{from{transform:translateY(0)}to{transform:translateY(-10px)}}
.v-title{font-size:2.2rem;font-weight:800;color:#fff;letter-spacing:-1px;}
.v-sub{font-size:.9rem;color:rgba(255,255,255,.75);margin-bottom:8px;}
.podium{width:100%;max-width:380px;display:flex;flex-direction:column;gap:6px;}
.podium-row{
  display:flex;align-items:center;gap:12px;
  background:rgba(255,255,255,.15);
  border-radius:8px;padding:10px 16px;
  font-weight:700;font-size:.95rem;color:#fff;
}
.podium-pos{font-size:1.3rem;font-weight:800;width:30px;}
.winner-row{background:rgba(255,255,255,.28)!important;border:2px solid rgba(255,255,255,.55);}

/* Toast */
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
  background:var(--dark);color:#fff;
  font-size:.82rem;font-weight:700;
  padding:9px 22px;border-radius:50px;
  z-index:300;
  animation:tin .25s ease, tout .25s ease 2.1s forwards;
  white-space:nowrap;
  box-shadow:0 4px 16px rgba(0,0,0,.3);
}
@keyframes tin {from{opacity:0;transform:translateX(-50%) translateY(14px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
@keyframes tout{from{opacity:1}to{opacity:0}}

/* Language toggle button */
.lang-toggle{
  position:fixed;top:12px;right:14px;z-index:500;
  display:flex;gap:0;border-radius:6px;overflow:hidden;
  box-shadow:0 2px 8px rgba(0,0,0,.2);
}
.lang-btn{
  background:rgba(255,255,255,.25);color:#fff;
  font-family:'Inter',sans-serif;font-size:.75rem;font-weight:700;
  border:none;padding:6px 12px;cursor:pointer;
  transition:background .15s;letter-spacing:.5px;
}
.lang-btn.active{background:#fff;color:var(--orange);}
.lang-btn:hover:not(.active){background:rgba(255,255,255,.4);}

/* Turn row tooltip */
.turn-row{position:relative;}
.turn-row .tr-tooltip{
  display:none;
  position:absolute;
  left:100%;top:50%;transform:translateY(-50%);
  margin-left:8px;
  background:var(--dark);color:#fff;
  font-size:.72rem;font-weight:600;
  padding:5px 10px;border-radius:6px;
  white-space:nowrap;
  box-shadow:0 2px 10px rgba(0,0,0,.25);
  pointer-events:none;
  z-index:50;
  line-height:1.5;
}
.turn-row .tr-tooltip::before{
  content:'';
  position:absolute;right:100%;top:50%;transform:translateY(-50%);
  border:5px solid transparent;
  border-right-color:var(--dark);
}
.turn-row:hover .tr-tooltip{display:block;}

/* Responsive */
@media(max-width:720px){
  .game-body{grid-template-columns:1fr;}
  .side-panel{flex-direction:row;flex-wrap:wrap;}
  .panel-card{flex:1 1 180px;}
}
</style>
</head>
<body>

<!-- Language toggle -->
<div class="lang-toggle">
  <button class="lang-btn active" id="btnPT" onclick="setLang('pt')">PT</button>
  <button class="lang-btn" id="btnES" onclick="setLang('es')">ES</button>
</div>

<!-- ══ SETUP ══ -->
<div id="setupScreen" class="screen active">
  <div style="width:100%;max-width:660px;padding-bottom:8px;">
    <div class="brand">
      <div class="brand-logo">Beleza<span> em Jogo</span></div>
      <div class="brand-sub">Jogo de Tabuleiro</div>
    </div>
    <div class="setup-tagline">Configure equipes e perguntas para começar</div>
  </div>

  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
      <div class="card-title" style="margin-bottom:0"><span>01</span> Equipes</div>
      <button class="btn sm" id="btnStartGame" onclick="startGame()" style="background:#1a6b4a;box-shadow:0 4px 14px rgba(26,107,74,.35);">▶ Iniciar Jogo</button>
    </div>
    <div class="teams-wrap" id="teamsList"></div>
    <div id="membersEditor" style="margin-top:16px;"></div>
  </div>

  <div class="card">
    <div class="card-title"><span>02</span> Perguntas</div>
    <p style="font-size:.82rem;color:var(--muted);margin-bottom:16px;">Cada pergunta deve ter 5 opções (A–E) e um gabarito definido.</p>
    <div id="questionBlocks"></div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn ghost sm" onclick="addQuestion()">+ Adicionar Pergunta</button>

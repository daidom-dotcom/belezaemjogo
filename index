function renderBoard(){
  const grid=document.getElementById('boardGrid');
  const cols=5, rows=Math.ceil(BOARD_SIZE/cols);
  grid.style.gridTemplateColumns=`repeat(${cols},1fr)`;
  grid.innerHTML='';

  // Build the visual snake path as an ordered list of [gridRow, gridCol]
  // Row 0: left→right (cols 0..4)
  // Row 1: right→left (cols 4..0)
  // etc.
  // We insert cells into the grid using explicit grid-column placement
  // so that visual position i always shows cell index i.
  // This means numbers always increase in the direction the eye reads.

  // First build a 2D grid of placeholders
  const gridSlots = Array.from({length:rows}, ()=>Array(cols).fill(null));

  // Map cell index → visual snake [row, col]
  const snakePath = [];
  for(let r=0;r<rows;r++){
    for(let c=0;c<cols;c++){
      const col = (r%2===0) ? c : (cols-1-c);
      snakePath.push([r, col]);
    }
  }

  for(let i=0;i<BOARD_SIZE;i++){
    const [r,c]=snakePath[i];
    gridSlots[r][c]=i;
  }

  // Render row by row, left to right — each cell placed via CSS grid-area
  for(let r=0;r<rows;r++){
    for(let c=0;c<cols;c++){
      const idx=gridSlots[r][c];
      if(idx===null){
        const e=document.createElement('div');
        e.style.cssText='opacity:0;aspect-ratio:1';
        grid.appendChild(e);
        continue;
      }
      const el=document.createElement('div');
      el.className='cell '+cellClass(idx);
      el.id=`cell_${idx}`;
      el.onclick=()=>onCellClick(idx);
      el.innerHTML=cellContent(idx);
      applyCellBg(idx, el);
      grid.appendChild(el);
    }
  }
}
function cellClass(idx){
  if(idx===0)return'start';
  if(idx===BOARD_SIZE-1)return'finish';
  const c=gameState.cells[idx];
  if(c.solved)return'solved';
  if(c.openedBy!==null)return'open';
  return'locked';
}
function cellContent(idx){
  const pawns=pawnsHtml(idx);
  if(idx===0)return`${pawns}<div class="cell-icon">🚩</div><div class="cell-num" style="color:#fff;opacity:.8">${t('cellStart')}</div>`;
  if(idx===BOARD_SIZE-1)return`${pawns}<div class="cell-icon">🏁</div><div class="cell-num" style="color:#fff;opacity:.8">${t('cellEnd')}</div>`;
  const c=gameState.cells[idx];
  let icon,numColor;
  if(c.solved){icon='✅';numColor='rgba(255,255,255,.9)';}
  else if(c.openedBy!==null){icon='❓';numColor='var(--orange)';}
  else{icon='';numColor='#ccc';}
  return`${pawns}<div class="cell-icon">${icon}</div><div class="cell-num" style="color:${numColor}">${idx}</div>`;
}
function applyCellBg(idx, el){
  const c=gameState.cells[idx];
  if(idx===0||idx===BOARD_SIZE-1) return; // handled by CSS class
  if(c.solved && c.solvedByTeam?.color){
    el.style.background=c.solvedByTeam.color;
  } else {
    el.style.background='';
  }
}
function pawnsHtml(idx){
  const here=gameState.teams.filter(tm=>tm.pos===idx&&!tm.finished);
  if(!here.length)return'';
  const curId=currentTeam()?.id;
  return`<div class="cell-pawns">${here.map(tm=>{
    const members=(tm.members||[]).filter(m=>m.trim());
    const tip=members.length?`${tm.name}: ${members.join(', ')}`:tm.name;
    return`<div class="pawn${tm.id===curId?' active-pawn':''}" style="background:${tm.color}" title="${tip}"></div>`;
  }).join('')}</div>`;
}
function refreshCells(...idxs){
  for(const idx of idxs){
    const el=document.getElementById(`cell_${idx}`);
    if(!el)continue;
    el.className='cell '+cellClass(idx);
    el.innerHTML=cellContent(idx);
    applyCellBg(idx, el);
  }
}

// ────────────────────────────────────────────────
//  DICE & MOVEMENT
// ────────────────────────────────────────────────
function currentTeam(){
  if(!gameState)return null;
  const id=gameState.order[gameState.curIdx%gameState.order.length];
  return gameState.teams.find(t=>t.id===id);
}
function updateTurnLabel(){
  const tm=currentTeam();
  const el=document.getElementById('turnName');
  if(el&&tm){el.textContent=tm.name;el.style.color=tm.color;}
  const btn=document.getElementById('rollBtn');
  if(btn)btn.disabled=gameState.diceRolled;
}
// ── Die face rotations (rotateX, rotateY) to show each number on front ──
// Layout: front=1, back=6, right=3, left=4, top=2, bottom=5
const FACE_ROTATIONS = {
  1: 'rotateX(0deg)   rotateY(0deg)',    // front
  6: 'rotateX(0deg)   rotateY(180deg)',  // back
  3: 'rotateX(0deg)   rotateY(-90deg)', // right
  4: 'rotateX(0deg)   rotateY(90deg)',  // left
  2: 'rotateX(-90deg) rotateY(0deg)',   // top
  5: 'rotateX(90deg)  rotateY(0deg)',   // bottom
};
function rollDice(){
  if(!gameState||gameState.diceRolled)return;
  const team=currentTeam();
  if(!team||team.finished){advanceTurn();return;}
  const dEl=document.getElementById('dice');
  // Animate: random spin then settle on face
  dEl.style.transition='none';
  dEl.style.transform=`rotateX(${Math.random()*720+360}deg) rotateY(${Math.random()*720+360}deg)`;
  dEl.classList.add('rolling');
  const roll=Math.floor(Math.random()*6)+1;
  setTimeout(()=>{
    dEl.classList.remove('rolling');
    dEl.style.transition='transform .5s ease';
    dEl.style.transform=FACE_ROTATIONS[roll];
  },550);
  document.getElementById('diceResult').textContent=t('diceResult',roll);
  const old=team.pos;
  let nxt=Math.min(team.pos+roll,BOARD_SIZE-1);
  if(nxt>0&&nxt<BOARD_SIZE-1)nxt=findAvail(nxt);
  team.pos=nxt;gameState.diceRolled=true;
  refreshCells(old,nxt);renderScorebar();updateTurnLabel();
  // Finish?
  if(nxt===BOARD_SIZE-1){
    gameState.finishCount++;team.finished=true;team.finishOrder=gameState.finishCount;
    toast(t('toastFinish',team.name,team.finishOrder));
    refreshCells(old,nxt);renderTurnOrder();renderScorebar();checkEnd();
    setTimeout(advanceTurn,1200);return;
  }
  if(nxt>0){
    const cell=gameState.cells[nxt];
    if(!cell.solved){
      cell.openedBy=team.id;refreshCells(nxt);
      setTimeout(()=>openModal(nxt,team),700);
    }else{setTimeout(advanceTurn,700);}
  }else{setTimeout(advanceTurn,700);}
}
function findAvail(target){
  // If target is solved, find the next available cell ahead
  if(!gameState.cells[target].solved) return target;
  for(let i=target+1;i<BOARD_SIZE-1;i++) if(!gameState.cells[i].solved) return i;
  return BOARD_SIZE-1; // reach finish if all ahead are solved
}
function findPrev(failedCell){
  for(let i=failedCell-1;i>=0;i--)if(i===0||gameState.cells[i].solved)return i;
  return 0;
}

// ────────────────────────────────────────────────
//  INLINE QUESTION PANEL
// ────────────────────────────────────────────────
let mState={};
function openModal(cellIdx,team){
  const q=questions[cellIdx-1];
  mState={cellIdx,team,answered:false};
  const panel=document.getElementById('questionPanel');
  document.getElementById('qPanelBadge').textContent=t('qLabel',cellIdx);
  document.getElementById('qPanelTeam').textContent=team.name;
  document.getElementById('qPanelTeam').style.color=team.color;
  document.getElementById('qPanelText').textContent=q[LANG]||q.pt||q.text||'';
  document.getElementById('qPanelResult').style.display='none';
  document.getElementById('qPanelResult').textContent='';
  document.getElementById('qPanelOpts').innerHTML=LETTERS.map(l=>`
    <button class="opt-btn" id="ob_${l}" onclick="answer('${l}')">
      <span class="opt-key">${l}</span>
      <span>${q.opts[l]||'—'}</span>
    </button>`).join('');
  document.getElementById('qPanelActions').innerHTML='';
  panel.style.display='block';
  panel.scrollIntoView({behavior:'smooth',block:'nearest'});
}
function answer(chosen){
  if(mState.answered)return;
  mState.answered=true;
  const q=questions[mState.cellIdx-1];
  const team=mState.team;
  const correct=q.correct;
  LETTERS.forEach(l=>{
    const b=document.getElementById(`ob_${l}`);
    if(b){
      b.onclick=null;
      if(chosen===correct){
        // only highlight on correct answer
        if(l===correct) b.classList.add('correct');
      } else {
        // wrong: just grey out chosen, don't reveal correct
        if(l===chosen) b.classList.add('wrong');
      }
    }
  });
  const r=document.getElementById('qPanelResult');
  r.style.display='block';
  if(chosen===correct){
    r.textContent=t('resultOk',team.name,mState.cellIdx);
    r.style.background='#e6f5ec'; r.style.color='#1a7a3a';
    const ansText=q.opts[correct]||correct;
    gameState.cells[mState.cellIdx].solved=true;
    gameState.cells[mState.cellIdx].openedBy=team.id;
    gameState.cells[mState.cellIdx].answerText=ansText;
    gameState.cells[mState.cellIdx].solvedByTeam={name:team.name,color:team.color};
    refreshCells(mState.cellIdx);
    renderDiscovered();
    // 🏆 House 24 answered correctly = game over!
    if(mState.cellIdx===BOARD_SIZE-2){
      gameState.winner=team;
      document.getElementById('qPanelActions').innerHTML=`<button class="btn confirm sm" style="width:100%;background:#FF6600" onclick="triggerVictory()">${t('btnContinue')}</button>`;
      return;
    }
  }else{
    r.textContent=t('resultNo');
    r.style.background='#fdecea'; r.style.color='#cc2200';
    const prev=findPrev(mState.cellIdx);
    team.pos=prev; refreshCells(mState.cellIdx,prev); renderScorebar();
  }
  document.getElementById('qPanelActions').innerHTML=`<button class="btn confirm sm" style="width:100%" onclick="confirmModal()">${t('btnContinue')}</button>`;
}
function confirmModal(){
  document.getElementById('questionPanel').style.display='none';
  advanceTurn();
}
function closeModal(){}  // no-op, kept for safety
function onCellClick(idx){
  if(!gameState||idx===0||idx===BOARD_SIZE-1)return;
  const c=gameState.cells[idx],team=currentTeam();
  if(!c.solved&&c.openedBy!==null&&team&&team.pos===idx&&gameState.diceRolled) openModal(idx,team);
}

// ────────────────────────────────────────────────
//  TURNS
// ────────────────────────────────────────────────
function advanceTurn(){
  gameState.diceRolled=false;
  document.getElementById('diceResult').textContent='';
  document.getElementById('questionPanel').style.display='none';
  const total=gameState.order.length;
  let next=(gameState.curIdx+1)%total,tries=0;
  while(tries<total){
    const id=gameState.order[next%total];
    const tm=gameState.teams.find(x=>x.id===id);
    if(!tm.finished){gameState.curIdx=next%total;break;}
    next++;tries++;
  }
  renderTurnOrder();updateTurnLabel();
}
function renderScorebar(){
  const curId=currentTeam()?.id;
  document.getElementById('scorebar').innerHTML=gameState.teams.map(tm=>`
    <div class="score-chip${tm.id===curId?' active':''}"
         title="${(tm.members||[]).filter(m=>m.trim()).join(', ')}">
      <div class="sc-dot" style="background:${tm.color}"></div>
      <span>${tm.name}</span>
      <span style="opacity:.65;font-size:.68rem;margin-left:3px">${tm.finished?t('scoreEnd'):t('scoreCasa',tm.pos)}</span>
    </div>`).join('');
}
function renderTurnOrder(){
  const curId=currentTeam()?.id;
  // Find who's leading: highest pos among non-finished; if tied, stable order
  const active=gameState.teams.filter(t=>!t.finished);
  const finished=gameState.teams.filter(t=>t.finished);
  let leaderId=null;
  if(finished.length>0){
    // whoever finished first leads
    leaderId=finished.sort((a,b)=>a.finishOrder-b.finishOrder)[0].id;
  } else if(active.length>0){
    const maxPos=Math.max(...active.map(t=>t.pos));
    const leaders=active.filter(t=>t.pos===maxPos);
    leaderId=leaders[0].id;
  }
  document.getElementById('turnOrderList').innerHTML=gameState.order.map(id=>{
    const tm=gameState.teams.find(x=>x.id===id);
    const isLeader=tm.id===leaderId;
    const memberStr=(tm.members||[]).filter(m=>m.trim()).join('\n');
    const tooltipHtml=memberStr?`<div class="tr-tooltip">${(tm.members||[]).filter(m=>m.trim()).map(m=>`• ${m}`).join('<br>')}</div>`:'';
    return`<div class="turn-row${tm.id===curId?' cur':''}${t.finished?' done':''}">
      <div style="display:flex;flex-direction:column;flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px">
          <div class="tr-dot" style="background:${tm.color}"></div>
          <span style="font-weight:800">${tm.name}${tm.finished?` — ${tm.finishOrder}º`:''}</span>
        </div>
        ${memberStr?`<div style="font-size:.68rem;color:var(--muted);margin-left:15px;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${(tm.members||[]).filter(m=>m.trim()).join(', ')}</div>`:''}
      </div>
      ${isLeader?`<span title="${LANG==='pt'?'Liderando!':'¡Liderando!'}" style="font-size:1rem;line-height:1">🏆</span>`:''}
      ${tooltipHtml}
    </div>`;
  }).join('');
}

// ────────────────────────────────────────────────
//  DISCOVERED ANSWERS
// ────────────────────────────────────────────────
function renderDiscovered(){
  const unsolved=[];
  for(let i=1;i<BOARD_SIZE-1;i++){
    if(!gameState.cells[i].solved){
      const q=questions[i-1];
      const ansText=q?.opts[q?.correct]||'';
      if(ansText) unsolved.push(ansText);
    }
  }
  const el=document.getElementById('discoveredList');
  if(!unsolved.length){el.innerHTML=`<div class="disc-empty">${t('discEmpty')}</div>`;return;}
  // Shuffle
  const shuffled=[...unsolved].sort(()=>Math.random()-.5);
  el.innerHTML=shuffled.map(ans=>`
    <div class="disc-item">
      <span class="disc-answer" style="color:var(--dark);font-weight:600">${escHtml(ans)}</span>
    </div>`).join('');
}
function escHtml(s){
  return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ────────────────────────────────────────────────
//  END GAME
// ────────────────────────────────────────────────
function triggerVictory(){
  document.getElementById('questionPanel').style.display='none';
  showVictory();
}
function checkEnd(){
  // kept for finish-line logic but main win = house 24
  if(gameState.teams.every(tm=>tm.finished)) showVictory();
}
function showVictory(){
  showScreen('victoryScreen');

  // Winner = team that solved house 24, or first finisher
  const winner = gameState.winner || gameState.teams.find(tm=>tm.finished);
  const subEl=document.getElementById('vWinnerSub');
  if(subEl) subEl.textContent=winner?`🎉 Vencedor: ${winner.name}!`:'Jogo encerrado!';

  // Ranking: teams sorted by number of houses conquered (solved)
  const solvedByTeam = {};
  gameState.cells.forEach((c,i)=>{
    if(i>0 && i<BOARD_SIZE-1 && c.solved && c.solvedByTeam){
      const key=c.solvedByTeam.name;
      solvedByTeam[key]=(solvedByTeam[key]||0)+1;
    }
  });
  const ranking=[...gameState.teams].sort((a,b)=>{
    // winner first
    if(winner && a.id===winner.id) return -1;
    if(winner && b.id===winner.id) return 1;
    return (solvedByTeam[b.name]||0)-(solvedByTeam[a.name]||0);
  });
  const medals=['🥇','🥈','🥉','4º','5º','6º'];
  document.getElementById('podium').innerHTML=ranking.map((tm,i)=>`
    <div class="podium-row${tm.id===winner?.id?' winner-row':''}">
      <span class="podium-pos">${medals[i]}</span>
      <div class="tr-dot" style="background:${tm.color};width:14px;height:14px;border-radius:50%;flex-shrink:0"></div>
      <span style="flex:1;font-weight:${tm.id===winner?.id?'800':'600'}">${tm.name}</span>
      <span style="font-size:.8rem;color:#888">${solvedByTeam[tm.name]||0} casas</span>
    </div>`).join('');

  // Undiscovered = questions never answered correctly
  const undiscovered=[];
  for(let i=1;i<BOARD_SIZE-1;i++){
    const c=gameState.cells[i];
    if(!c.solved){
      const q=questions[i-1];
      const ans=q?.opts[q?.correct]||'';
      if(ans) undiscovered.push(ans);
    }
  }
  const undiscEl=document.getElementById('victoryUndiscovered');
  if(undiscEl){
    if(undiscovered.length){
      undiscEl.innerHTML=`
        <div style="margin-top:20px;max-width:420px;width:100%">
          <div style="font-size:.75rem;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px">Não descobertos</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center">
            ${undiscovered.map(name=>`<span style="background:rgba(255,255,255,.15);color:#fff;padding:4px 12px;border-radius:50px;font-size:.82rem;font-weight:600">${escHtml(name)}</span>`).join('')}
          </div>
        </div>`;
    } else {
      undiscEl.innerHTML=`<div style="margin-top:16px;font-size:.85rem;color:rgba(255,255,255,.7)">Todos descobertos! 🎉</div>`;
    }
  }
}
function resetGame(){
  questions=[];qCount=0;gameState=null;
  document.getElementById('questionBlocks').innerHTML='';
  document.getElementById('diceResult').textContent='';
  const dEl=document.getElementById('dice');
  if(dEl){dEl.style.transition='none';dEl.style.transform=FACE_ROTATIONS[1]||'rotateX(0deg) rotateY(0deg)';}
  updateQCount();
  initTeams();
  showScreen('setupScreen');
}

// ────────────────────────────────────────────────
//  UTILS
// ────────────────────────────────────────────────
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function toast(msg){
  const tel=document.createElement('div');tel.className='toast';tel.textContent=msg;
  document.body.appendChild(tel);setTimeout(()=>tel.remove(),2500);
}

updateQCount();

// ────────────────────────────────────────────────
//  LANGUAGE SYSTEM
// ────────────────────────────────────────────────

function setLang(lang){
  LANG = lang;
  document.getElementById('btnPT').classList.toggle('active', lang==='pt');
  document.getElementById('btnES').classList.toggle('active', lang==='es');
  applyLangToStaticHTML();
  // Re-render dynamic parts if game is running
  if(gameState){
    renderScorebar(); renderTurnOrder(); renderDiscovered();
    renderBoard();
    const qPanel=document.getElementById('questionPanel');
    if(qPanel && qPanel.style.display!=='none' && mState.cellIdx){
      // re-render current question panel text
      const q=questions[mState.cellIdx-1];
      document.getElementById('qPanelBadge').textContent=t('qLabel',mState.cellIdx);
      document.getElementById('qPanelText').textContent=q[LANG]||q.pt||q.text||'';
    }
  }
  // Re-render question blocks in setup
  rerenderQuestionBlocks();
}

function applyLangToStaticHTML(){
  // Setup screen
  const bl=document.querySelector('.brand-logo');        if(bl) bl.innerHTML=t('brandLogo');
  const bs=document.querySelector('.brand-sub');         if(bs) bs.textContent=t('brandSub');
  const tl=document.querySelector('.setup-tagline');     if(tl) tl.textContent=t('tagline');
  const ct=document.querySelectorAll('.card-title');
  if(ct[0]) ct[0].innerHTML=t('card1Title');
  if(ct[1]) ct[1].innerHTML=t('card2Title');
  const cp=document.querySelectorAll('.card > p');
  if(cp[0]) cp[0].innerHTML=t('card1Desc');
  if(cp[1]) cp[1].innerHTML=t('card2Desc');
  const baq=document.querySelector('[onclick="addQuestion()"]');         if(baq) baq.textContent=t('btnAddQ');
  const bsq=document.querySelector('[onclick="fillSampleQuestions()"]'); if(bsq) bsq.textContent=t('btnSample');
  const bst=document.getElementById('btnStartGame'); if(bst) bst.textContent=t('btnStart');
  // Game screen — by ID
  const ptd=document.getElementById('panelTitleDice');  if(ptd) ptd.textContent=t('panelDado');
  const pto=document.getElementById('panelTitleOrder'); if(pto) pto.textContent=t('panelOrdem');
  const dw =document.querySelector('.dice-who');         if(dw)  dw.textContent=t('panelVez');
  const rb =document.getElementById('rollBtn');          if(rb)  rb.textContent=t('btnRoll');
  const ds =document.getElementById('discSubtitle');     if(ds)  ds.textContent=t('discSubtitle');
  // Question panel title prefix
  const qpt=document.querySelector('#questionPanel .panel-title');
  if(qpt && mState.cellIdx) qpt.innerHTML=`${t('qPanelTitle')} <span id="qPanelBadge" style="color:var(--orange)">${t('qLabel',mState.cellIdx)}</span>`;
  // Victory screen
  const vt=document.querySelector('.v-title');                           if(vt) vt.textContent=t('vTitle');
  const vs=document.querySelector('.v-sub');                             if(vs) vs.textContent=t('vSub');
  const vb=document.querySelector('.btn.white[onclick="resetGame()"]');  if(vb) vb.textContent=t('btnReset');
  // Topbar logo stays bilingual-neutral
}

function rerenderQuestionBlocks(){
  // Update label text inside existing question blocks
  document.querySelectorAll('.q-block').forEach(block=>{
    const n=block.id.split('_')[1];
    const numEl=block.querySelector('.q-block-num');
    if(numEl) numEl.textContent=t('qBlockLabel',n);
    // labels
    const labels=block.querySelectorAll('label');
    if(labels[0]) labels[0].textContent=t('labelEnunc');
    if(labels[1]) labels[1].textContent=t('labelOpts');
    if(labels[2]) labels[2].textContent=t('labelGab');
    // textarea placeholder
    const ta=block.querySelector('textarea');
    if(ta) ta.placeholder=t('placeholderQ');
    // input placeholders for options
    LETTERS.forEach(l=>{
      const inp=document.getElementById(`qo_${n}_${l}`);
      if(inp) inp.placeholder=`${LANG==='pt'?'Opção':'Opción'} ${l}`;
    });
    // Swap question text textarea to correct language
    const q=questions[parseInt(n)-1];
    if(q && ta){
      ta.value = q[LANG] || q.pt || q.text || ta.value;
    }
  });
}

// Kick off on load
applyLangToStaticHTML();
initTeams();

